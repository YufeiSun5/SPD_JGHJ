# ===================================
# IIoT 网关系统配置文件
# ===================================

# 服务器配置
SERVER_PORT=8080
GIN_MODE=debug

# 数据库配置 (PostgreSQL/MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=spd_jghj
DB_SSLMODE=disable

# MQTT配置 (已废弃 - 现在从数据库 sys_gateways 表读取多网关配置)
# 以下配置仅用于兼容旧代码,实际不再使用
MQTT_BROKER=tcp://127.0.0.1
MQTT_PORT=1883
MQTT_CLIENT_ID=legacy-client
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_KEEP_ALIVE=60
MQTT_CLEAN_SESSION=false
MQTT_AUTO_RECONNECT=true
MQTT_MAX_RECONNECT_INTERVAL=10

# 生产系数配置
PRODUCTION_COEFFICIENT=100.0
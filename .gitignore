# ============================================================
# SPD_JGHJ .gitignore
# Go + Wails + Vue 3 + Python AI 后端
# ============================================================

# ── Go 工具链 / SDK（.vfox 管理，体积极大，不入库）──────────
.vfox/
desktop/.vfox/

# ── Go 编译缓存 / 模块缓存 ───────────────────────────────────
*.exe
!desktop/build/bin/*.exe

# ── Wails 构建产物 ────────────────────────────────────────────
desktop/build/bin/
desktop/dist/

# ── 根目录遗留旧可执行文件 ────────────────────────────────────
gin-mqtt-pgsql.exe
iot-gateway.exe
desktop/desktop.exe
desktop/test_build.exe

# ── 打包后的可执行文件目录 ────────────────────────────────────
打包后的可执行文件/

# ── 前端依赖 ─────────────────────────────────────────────────
desktop/frontend/node_modules/

# ── Python AI 后端虚拟环境 ────────────────────────────────────
AI/fastAPI/fastAPI/venv_offline/
AI/fastAPI/fastAPI/venv/
AI/fastAPI/fastAPI/whl_packages/
AI/fastAPI/fastAPI/models/embedding_cache/
AI/**/__pycache__/
AI/**/*.pyc

# ── 临时文件 ──────────────────────────────────────────────────
.tmp-bin/
*.tmp
*.log

# ── IDE / 编辑器 ──────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── OS 文件 ───────────────────────────────────────────────────
Thumbs.db
.DS_Store
